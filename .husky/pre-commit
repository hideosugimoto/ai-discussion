echo "🔄 Pre-commit: モデル表示を models.config.js から同期..."
# config のモデル変更が LP/README のマーカー領域へ自動反映される。sync が実際に
# 書き換えたファイルだけを同コミットへステージし、無関係な未ステージ編集は
# 巻き込まない。
tmp=$(mktemp -d)
cp public/lp.html "$tmp/lp.html"
cp README.md "$tmp/README.md"
npm run sync:models || { rm -rf "$tmp"; exit 1; }
cmp -s "$tmp/lp.html" public/lp.html || git add public/lp.html
cmp -s "$tmp/README.md" README.md || git add README.md
rm -rf "$tmp"
